DirectorySlash Off
ErrorDocument 404 /404.html
Require all granted

<IfModule mod_headers.c>
	# Astro hashed assets — immutable, 1 year
	<If "%{REQUEST_URI} =~ m#^/_astro/#">
		Header set Cache-Control "immutable, max-age=31536000, public"
	</If>

	# Astro HTML pages — 1 minute
	<If "%{REQUEST_URI} !~ m#^/app/sk/map/# && (%{REQUEST_URI} =~ m#^/[^.]*$# || %{REQUEST_URI} =~ m#^/404\.html$#)">
		Header set Cache-Control "max-age=60, public"
	</If>

	# Cookie consent library — revalidate every request
	<If "%{REQUEST_URI} =~ m#^/frontend/assets/js/cookieconsent\.js#">
		Header set Cache-Control "no-cache"
	</If>
</IfModule>

<IfModule mod_rewrite.c>
	RewriteEngine On

	# Redirect HTTP to HTTPS
	RewriteCond %{HTTPS} !on
	RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

	# Block dotfiles
	RewriteRule (^|/)\. - [F]

	# Block direct index.html access
	RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
	RewriteRule ^ - [L,R=404]

	# Serve index.html for directory requests
	RewriteCond %{REQUEST_FILENAME} -d
	RewriteCond %{REQUEST_FILENAME}/index.html -f
	RewriteRule (.*) $1/index.html [L]

	# Nette app routing
	RedirectMatch 301 ^/app/sk/map/?$ /app/sk/map/zoznam/
	RewriteCond %{REQUEST_URI} ^/app/sk/map/
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule . index.php [L]
</IfModule>
